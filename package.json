{
  "name": "noraebang",
  "version": "0.1.0",
  "description": "집에서 즐기는 데스크톱 노래방 앱",
  "main": "main.js",
  "scripts": {
    "start": "PIPEWIRE_LATENCY=64/48000 electron . --no-sandbox",
    "start:mac": "electron .",
    "dist:mac": "electron-builder --mac --arm64 --publish never",
    "dist:mac-universal": "electron-builder --mac --universal --publish never"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.minsung.noraebang",
    "productName": "노래방",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "styles.css",
      "renderer.js"
    ],
    "mac": {
      "category": "public.app-category.music",
      "icon": "build/icon.png",
      "target": [
        "dmg"
      ],
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "extendInfo": {
        "NSMicrophoneUsageDescription": "노래방 앱에서 노래를 녹음하려면 마이크 접근이 필요합니다."
      }
    }
  }
}
